# Ubah nilai di bawah ini dengan path (lokasi) file Excel rekap nilai di laptop/komputer Anda masing-masing.
# Contoh format path di Windows (gunakan backslash ganda \\ atau raw string, namun untuk di file .env cukup gunakan backslash biasa atau slash /):
# EXCEL_PATH="C:\Users\NamaAnda\Documents\TugasPBO\rekap_nilai.xlsx"

EXCEL_PATH="C:\path\to\your\excel\file\tugas.xlsx"
